# Elasticsearch & Kibana version
STACK_VERSION=8.12.2

# Elasticsearch cluster name
CLUSTER_NAME=es-cluster

# Elasticsearch password for the 'elastic' user (반드시 변경하세요 / change before production use)
ELASTIC_PASSWORD=P@ssw0rd

# Kibana password for the 'kibana_system' user (반드시 변경하세요 / change before production use)
KIBANA_PASSWORD=P@ssw0rd

# Elasticsearch HTTP port
ES_PORT=9200

# Kibana HTTP port
KIBANA_PORT=5601

# Memory limit for Elasticsearch container (in bytes)
MEM_LIMIT=1073741824
